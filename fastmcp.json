{
  "mcpServers": {
    "model-council-mcp-server": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "model_council_mcp_server.server"
      ],
      "cwd": ".",
      "env": {
        "POLZA_BASE_URL": "https://polza.ai/api/v1",
        "COUNCIL_CHINA_MOONSHOT_MODEL": "moonshotai/kimi-k2.5",
        "COUNCIL_CHINA_QWEN_MODEL": "qwen/qwen3.6-plus",
        "COUNCIL_CHINA_DEEPSEEK_MODEL": "deepseek/deepseek-v3.2",
        "COUNCIL_USA_GEMINI_MODEL": "google/gemini-3.1-flash-lite-preview",
        "COUNCIL_USA_GROK_MODEL": "x-ai/grok-4.1-fast",
        "COUNCIL_USA_OPENAI_MODEL": "openai/gpt-5.4-nano",
        "LOG_LEVEL": "INFO"
      }
    }
  },
  "server": {
    "name": "model-council-mcp-server",
    "version": "0.1.0",
    "description": "Three raw model perspectives from Grok, Gemini, and DeepSeek for Claude to summarize",
    "entrypoint": "model_council_mcp_server.server:create_app",
    "dependencies": [
      "fastmcp>=2.11.0",
      "httpx>=0.28.1",
      "pydantic>=2.8.2"
    ],
    "environment": {
      "POLZA_API_KEY": {
        "required": true,
        "description": "Polza API key"
      },
      "POLZA_BASE_URL": {
        "required": false,
        "default": "https://polza.ai/api/v1",
        "description": "Base URL for the Polza API"
      },
      "COUNCIL_CHINA_MOONSHOT_MODEL": {
        "required": false,
        "default": "moonshotai/kimi-k2.5",
        "description": "China preset Kimi model id"
      },
      "COUNCIL_CHINA_QWEN_MODEL": {
        "required": false,
        "default": "qwen/qwen3.6-plus",
        "description": "China preset Qwen model id"
      },
      "COUNCIL_CHINA_DEEPSEEK_MODEL": {
        "required": false,
        "default": "deepseek/deepseek-v3.2",
        "description": "China preset DeepSeek model id"
      },
      "COUNCIL_USA_GEMINI_MODEL": {
        "required": false,
        "default": "google/gemini-3.1-flash-lite-preview",
        "description": "USA preset Gemini model id"
      },
      "COUNCIL_USA_GROK_MODEL": {
        "required": false,
        "default": "x-ai/grok-4.1-fast",
        "description": "USA preset Grok model id"
      },
      "COUNCIL_USA_OPENAI_MODEL": {
        "required": false,
        "default": "openai/gpt-5.4-nano",
        "description": "USA preset OpenAI model id"
      },
      "LOG_LEVEL": {
        "required": false,
        "default": "INFO",
        "description": "Logging level"
      }
    }
  }
}
